{
  "compilerOptions": {
    "checkJs": false,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["client/src/store/types/**/*", "server/models/types/**/*"]
}
